APP_NAME="Estevo Solar"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://solar.estevo.tech

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=estevo_solar
DB_USERNAME=estevo_solar
DB_PASSWORD=TROQUE_ESTA_SENHA_FORTE

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.estevo.tech

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# Empresa exibida na landing e mensagens WhatsApp
EMPRESA_NOME="Estevo Solar"
EMPRESA_WHATSAPP=5568999999999

# Parâmetros solares (Acre)
SOLAR_HSP=4.5
SOLAR_EFICIENCIA=0.80
SOLAR_TARIFA_KWH=0.92
SOLAR_POTENCIA_PLACA_W=550
SOLAR_PRECO_POR_KWP=4800.00
SOLAR_MARGEM_VARIACAO=0.10

# Gemini Vision — leitura automática da conta de luz
GEMINI_API_KEY=COLE_SUA_CHAVE_GEMINI
GEMINI_MODEL=gemini-2.5-flash-lite

# Admin do painel Filament (criado pelo seeder)
ADMIN_EMAIL=admin@estevo.tech
ADMIN_NAME="Admin Estevo"
ADMIN_PASSWORD=TROQUE_ESTA_SENHA_FORTE
